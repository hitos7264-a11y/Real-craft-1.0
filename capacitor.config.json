{
  "appId": "com.hrgm.voxelworld",
  "appName": "VoxelWorld",
  "webDir": ".",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "backgroundColor": "#0a0c10"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1800,
      "launchAutoHide": true,
      "backgroundColor": "#0a0c10",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#0a0c10"
    }
  }
}
